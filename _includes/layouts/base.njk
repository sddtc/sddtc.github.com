{% set currentLang = lang or i18n.defaultLanguage %}
{% set currentHtmlLang = "zh-CN" if currentLang == "zh" else "en" %}
<!doctype html>
<html lang="{{ currentHtmlLang }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title or ("siteTitle" | t(currentLang)) }}</title>
		<meta name="description" content="{{ description or metadata.description }}">
		<link rel="icon" href="/img/favicon.ico" />
		<meta name="generator" content="{{ eleventy.generator }}">
		<link rel="canonical" href="{{ metadata.url }}{{ page.url }}">
		<link rel="alternate" hreflang="zh" href="{{ metadata.url }}{{ page.url | localizedUrl("zh") }}">
		<link rel="alternate" hreflang="en" href="{{ metadata.url }}{{ page.url | localizedUrl("en") }}">
		<link rel="alternate" hreflang="x-default" href="{{ metadata.url }}/">

		{#- Add the contents of a file to the bundle #}
		<style>{% include "css/index.css" %}</style>
		<style>{% include "css/customized-theme.css" %}</style>

		{#- Render the CSS bundle using inlined CSS (for the fastest site performance in production) #}
		<style>{% getBundle "css" %}</style>

		{#- Renders the CSS bundle using a separate file, if you can't set CSP directive style-src: 'unsafe-inline' #}
		{#- <link rel="stylesheet" href="{% getBundleFileUrl "css" %}"> #}

		{#- Add the heading-anchors web component to the JavaScript bundle #}
		<script type="module">{% include "node_modules/@zachleat/heading-anchors/heading-anchors.js" %}</script>
	</head>
	<body>
		<a href="#main" id="skip-link" class="visually-hidden">Skip to main content</a>

		<header>
			<div class="page-wrap header-inner">
				<a href="{{ "/" | localizedUrl(currentLang) }}" class="home-link">{{ "siteTitle" | t(currentLang) }}</a>

				<nav>
					<h2 class="visually-hidden">Top level navigation menu</h2>
					<ul class="nav">
						{% set navItems = [
							{ key: "nav.home", url: "/" },
							{ key: "nav.categories", url: "/categories/" },
							{ key: "nav.tags", url: "/tags/" },
							{ key: "nav.blog", url: "/blog/" },
							{ key: "nav.about", url: "/about/" }
						] %}
						{%- for item in navItems %}
							{% set itemUrl = item.url | localizedUrl(currentLang) %}
							{% set isCurrent = itemUrl == page.url or (item.url != "/" and page.url and page.url.indexOf(itemUrl) == 0) %}
							<li class="nav-item"><a href="{{ itemUrl }}"{% if isCurrent %} aria-current="page"{% endif %}>{{ item.key | t(currentLang) }}</a></li>
						{%- endfor %}
					</ul>
				</nav>

				<div class="language-switcher" aria-label="{{ "language.switcher" | t(currentLang) }}">
					<a href="{{ page.url | localizedUrl("zh") }}"{% if currentLang == "zh" %} aria-current="true"{% endif %} onclick="window.blog && window.blog.storeLanguagePreference('zh')">{{ "language.zh" | t(currentLang) }}</a>
					<a href="{{ page.url | localizedUrl("en") }}"{% if currentLang == "en" %} aria-current="true"{% endif %} onclick="window.blog && window.blog.storeLanguagePreference('en')">{{ "language.en" | t(currentLang) }}</a>
				</div>
			</div>
		</header>

		<main id="main">
			<div class="page-wrap">
				<heading-anchors>
					{{ content | safe }}
				</heading-anchors>
			</div>
		</main>

		<footer>
			<div class="page-wrap">
				<p>Copyright © <span id="copyright-year"></span></p>
			</div>
		</footer>

		<script>
		; (function () {
			var el = document.getElementById('copyright-year');
			if (el) el.textContent = new Date().getFullYear();
		})();
		</script>

    <script type="module">{% include "js/customized-bundle.js" %}</script>
		<script>
		; (function () {
			var textArr = ['富强', '民主', '文明', '和谐', '自由', '平等', '公正', '法治', '爱国', '敬业', '诚信', '友善']
			window.blog.initCodeCopyButtons()
			window.blog.initClickEffect(textArr)
		})()
		</script>

		<!-- google analysis start -->
		<script type="text/javascript">{% include "js/google-analysis.js" %}</script>
		<!-- google analysis start -->

		<!-- Global site tag (gtag.js) - Google Analytics -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-KVM27VFBYL"></script>
		<script>
		window.dataLayer = window.dataLayer || [];
		function gtag() { dataLayer.push(arguments); }
		gtag('js', new Date());

		gtag('config', 'G-KVM27VFBYL');
		</script>
		<!-- Global site tag (gtag.js) - Google Analytics end -->

		<!-- This page `{{ page.url }}` was built on {% currentBuildDate %} -->
		<script type="module" src="{% getBundleFileUrl "js" %}"></script>
	</body>
</html>
