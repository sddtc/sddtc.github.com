<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title or metadata.title }}</title>
		<meta name="description" content="{{ description or metadata.description }}">
		<link rel="icon" href="/img/favicon.ico" />
		<meta name="generator" content="{{ eleventy.generator }}">
		<style>{% include "css/index.css" %}</style>
		<style>{% include "css/customized-theme.css" %}</style>
	</head>
	<body>
		<main id="main">
			<div class="page-wrap">
				{{ content | safe }}
			</div>
		</main>

		<script type="module">{% include "js/customized-bundle.js" %}</script>
		<script>
		; (function () {
			if (window.blog && window.blog.initLanguageEntry) {
				window.blog.initLanguageEntry({ zh: '/zh/', en: '/en/' })
			}
		})()
		</script>
		<script type="module" src="{% getBundleFileUrl "js" %}"></script>
	</body>
</html>
